{
  "root_name": "",
  "config_name": "default",
  "base_config": {
    "output": "./data/output.json",
    "concurrency": 5,
    "delay": 1000,
    "random_delay": 500,
    "timeout": 30,
    "max_retries": 3,
    "retry_delay": 2000,
    "backoff_policy": 2,
    "max_log_size": 50
  },
  "web": {
    "black_list": [
      "192.168.1.",
      "admin.",
      "login",
      "logout"
    ]
  },
  "agents": {
    "proxy": "http://127.0.0.1:7890",
    "proxy_rotation_strategy": "round_robin",
    "id": "agent_001",
    "ip": "1.2.3.4",
    "headers": {
      "Accept-Language": [
        "zh-CN,zh;q=0.9,en;q=0.8"
      ],
      "Referer": [
        "https://www.google.com/"
      ],
      "User-Agent": [
        "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36"
      ]
    },
    "cookies": [
      {
        "Name": "session_id",
        "Value": "abc123xyz",
        "Quoted": false,
        "Path": "/",
        "Domain": ".example.com",
        "Expires": "0001-01-01T00:00:00Z",
        "RawExpires": "",
        "MaxAge": 0,
        "Secure": true,
        "HttpOnly": true,
        "SameSite": 0,
        "Partitioned": false,
        "Raw": "",
        "Unparsed": null
      },
      {
        "Name": "user_pref",
        "Value": "dark_mode",
        "Quoted": false,
        "Path": "/settings",
        "Domain": "example.com",
        "Expires": "0001-01-01T00:00:00Z",
        "RawExpires": "",
        "MaxAge": 0,
        "Secure": false,
        "HttpOnly": false,
        "SameSite": 0,
        "Partitioned": false,
        "Raw": "",
        "Unparsed": null
      }
    ]
  },
  "custom_domains": {
    "api.example.com": {
      "output": "./data/api_data.json",
      "concurrency": 10,
      "delay": 500,
      "random_delay": 200,
      "timeout": 15,
      "max_retries": 5,
      "retry_delay": 1000,
      "backoff_policy": 1,
      "max_log_size": 20
    },
    "static.example.com": {
      "output": "./data/static_assets.json",
      "concurrency": 20,
      "delay": 0,
      "random_delay": 0,
      "timeout": 60,
      "max_retries": 1,
      "retry_delay": 0,
      "backoff_policy": 0,
      "max_log_size": 100
    }
  },
  "render": {
    "enable": true,
    "engine": "chromium",
    "headless": true,
    "wait_until": "networkidle"
  },
  "next": [],
  "next_name": [
    "default"
  ],
  "Reprocess": ""
}